{
  "id": "knights-murdoku",
  "title": "Knights Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "- Pawns cannot be occupied.",
    "- Everyone has at least 2 other person in a knight move away from them except the left most person and the victim that only has 1. (Ignoring walls)"
  ],
  "rules": [
    "- Only 1 person can be per row and per column.",
    "- \"Besides\" means same room and orthogonally adjacent",
    "- \"South\" does not necessarily mean in the same column unless specified."
  ],
  "clues": [
    "A (Men   - Alfred) is north of Cory and is alone",
    "B (Woman - Betty) is in the last 3 rows",
    "C (Men   - Cory) has 2 out of his 3 neighbouring  rooms populated",
    "D (Men   - Dylan) is alone in room 9",
    "E (Woman - Ella) has a pawn south of her, in the same column. She is also south of Francis",
    "F (Men   - Francis) is with a woman in room 1",
    "G (Woman - Gina) has exactly 2 pawns in her row",
    "H (Woman - Helen) is either east of Dylan or west of Cory",
    "V (Men   - Vincent) is the victim and is alone with the killer"
  ],
  "difficulty": "Very hard",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "clickActionRight": "cross",

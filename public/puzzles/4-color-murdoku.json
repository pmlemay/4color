{
  "id": "4-color-murdoku",
  "title": "4-Color Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "All regions start with exactly 2 colored square.",
    "All regions had different total height.",
    "All regions had different total width."
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally adjacent.",
    "Color each region so that no two adjacent regions share the same color.",
    "All cells in a region must be the same color."
  ],
  "clues": [
    "A (Woman - Adelaide). She was in a region of height 2.",
    "B (Man - Bernard). He was not in a green region. He was north of Gertrude.",
    "C (Man - Chester). He was on the same diagonal and same region as Gertrude. He was also north of Bernard.",
    "D (Man - Diego). He was on the north-most row of his region but not on the first row.",
    "E (Man - Edgar). He was in the 5th row. He was also west of Chester.",
    "F (Man - Franklin). He was in the same diagonal as Adelaide in the orange region.",
    "G (Woman - Gertrude). She was in the highest total height and highest total width region. (i.e. no region was wider nor taller than hers)",
    "V (Woman - Vanessa). The victim. She was alone with the murderer."
  ],
  "difficulty": "Expert",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",

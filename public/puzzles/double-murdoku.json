{
  "id": "double-murdoku",
  "title": "Double Murdoku - Clean Up",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "Every row and every column had 2 people: 1 man and 1 woman.",
    "Every room had 2 people: 1 man and 1 woman.",
    "No icons can be occupied"
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. They were in a region alone with the victim.",
    "\"Beside\" means in the same room and orthogonally adjacent.",
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column."
  ],
  "clues": [
    "A (Man - Albert). He was beside a cleaning cart.",
    "B (Man - Booker). He was in the third column but not in Dream Den.",
    "C (Man - Cory). He was beside a table.",
    "D (Man - Dimitri). He was south of Gerry.",
    "E (Man - Eric). He was beside a bookcase.",
    "F (Man - Fred). He was beside a vacuum robot.",
    "G (Man - Gerry). He was either in Leisure Loft or Comfort Cove.",
    "H (Man - Harvey). He was in the same column as the woman in his room.",
    "I (Woman - Iris) She was beside a table, east of Joy.",
    "J (Woman - Joy) She was beside a bookcase.",
    "K (Woman - Karen) She was in the same row as Albert.",
    "L (Woman - Lois) She was one row south of Harvey.",
    "M (Woman - Mary) She was in Dream Den, Mellow Meadow or Serene Station..",
    "N (Woman - Nikita) She was in the Zen Zone.",
    "O (Woman - Ophelia) She was beside a polisher machine.",
    "V (Woman - Virginia). The victim. She was alone with the murderer."
  ],
  "difficulty": "Very hard",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],

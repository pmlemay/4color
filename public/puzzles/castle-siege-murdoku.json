{
  "id": "castle-siege-murdoku",
  "title": "Castle Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "Only the throne and horses can be occupied, other icons cannot."
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally adjacent."
  ],
  "clues": [
    "A (Man - Archibald). He was beside a banner in the Great Hall.",
    "B (Man - Booker). He was beside the throne.",
    "C (Woman - Celia). She was beside the gates in the Ramparts and also east of Karl.",
    "D (Man - Dante). He was one column east of an occupied horse.",
    "E (Man - Elliott). He was in the War Room.",
    "F (Man - Fletcher). He was on the walkway in the Forge, the Throne Room or the Great Hall.",
    "G (Woman - Giselle). She was beside hay, on the walkway.",
    "H (Man - Herbert). He was in the Chapel but not on the walkway.",
    "I (Woman - Ivy). She was one row north of a training dummy but not on the walkway.",
    "J (Man - Joel). He was with two other people.",
    "K (Man - Karl). He was in the Dungeon.",
    "V (Woman - Veronica). The victim. She was alone with the murderer."
  ],
  "difficulty": "Very hard",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",
  "clickActionRight": "cross",
  "gridSize": {
    "rows": 12,
    "cols": 12
  },

{
  "id": "castle-siege-murdoku",
  "title": "Castle Murdoku",
  "authors": [
    "PmLemay"
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally adjacent."
  ],
  "clues": [
    "A (Man - Archibald). He was beside a banner in the Great Hall.",
    "B (Man - Booker). He was beside the throne.",
    "C (Woman - Celia). She was beside the gates in the Ramparts.",
    "D (Man - Dante). He was beside a horse.",
    "E (Man - Elliott). He was in the War Room.",
    "F (Man - Fletcher). He was on the walkway in the Forge, the Tower or the Gatehouse.",
    "G (Woman - Giselle). She was in the cellar.",
    "H (Man - Herbert). He was not on the road in the Chapel.",
    "I (Woman - Ivy). She was in the last row, on the walkway.",
    "J (Man - Joel). He was in the kitchen, beside a soup pot.",
    "K (Man - Karl). He was in the Dungeon.",
    "V (Woman - Veronica). The victim. She was alone with the murderer."
  ],
  "difficulty": "Medium",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",
  "clickActionRight": "cross",

{
  "id": "murdoku-highschool",
  "title": "Murdoku Highschool",
  "authors": [
    "JacobTW2"
  ],
  "specialRules": [
    "There was one teacher per classroom",
    "Each classroom was of the subject of the teacher inside of it"
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally adjacent."
  ],
  "clues": [
    "A (Man - Arthur). Art Teacher - There was a student in the top row of his classroom",
    "B (Woman - Bianca). Biology Teacher. She was beside a microscope",
    "C (Man - Charles). Chemistry Teacher. He was alone with a student  southeast of him that was in a chair",
    "D (Man - Draco). Drama Teacher. He was the only teacher in a chair. He was east of charles",
    "E (Man - Ernest). He was in the biology classroom with another student. He was one space below an object",
    "F (Man - Fabian). He was beside a basketball",
    "G (Woman - Gladys). She was in the top row",
    "H (Man - Hawke). He was the only person beside a computer",
    "I (Man - Idris). He was in the same row as the bus stop",
    "J (Woman - Jodie). She was in the bottom right of corner of a classroom",
    "L (Man - Liam). There was a table in his row. He was west of Idris",
    "K (Man - Keiran). He was beside a locker. South of it",
    "M (Woman - Martina). She was in the drama classroom and south of Fabian",
    "V (Man - Vincent). The victim. He was alone with the murderer."
  ],
  "difficulty": "Hard",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",
  "clickActionRight": "cross",

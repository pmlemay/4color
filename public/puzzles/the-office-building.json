{
  "id": "the-office-building",
  "title": "The Office Building Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "'Same position' refers to individual floor grids.",
    "This is a single 10x10 grid with space in-between floors so a row in 1F affects 2F.",
    "Only chairs can be occupied, the other icons cannot."
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally adjacent."
  ],
  "clues": [
    "A (Woman - Alice). She was in the elevator in one of the first 2 floors.",
    "B (Woman - Blanche). She was on the third floor, but not in the second column.",
    "C (Man - Chester). He was in the same position as Gareth on another floor.",
    "D (Woman - Daisy). She was on the balcony",
    "E (Woman - Elena). She was on the Rooftop in the same position as someone in the cafeteria.",
    "F (Man - Fergus). He was beside a bookcase.",
    "G (Man - Gareth). He was in Office 2B.",
    "H (Woman - Holly). She was on a lower floor than Fergus.",
    "I (Man - Igor). He was the only one sitting beside a computer.",
    "V (Woman - Valentina). The victim. She was alone with the murderer."
  ],
  "difficulty": "Medium",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",
  "clickActionRight": "cross",

{
  "id": "hockey-game-murdoku",
  "title": "Hockey Game Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "Every cell/icon can be occupied.",
    "All hockey players were either in the Players Bench, the Ice Rink or the Penalty Bench. No one else was can be there."
  ],
  "rules": [
    "Place everyone on the grid according to their clue to find the murderer. He was in a region alone with the victim.",
    "Only 1 person per row and per column.",
    "\"Beside\" means in the same room and orthogonally connected.",
    "\"Adjacent\" means orthogonally connected but not necessarily in the same room.",
    "\"Outer edge\" means first row + last row + first column + last column."
  ],
  "clues": [
    "A (Man - Adam). Hockey Player. He was beside a goal.",
    "B (Man- Ben). Hockey Player. He was south of Adam and west of Gerald",
    "C (Man - Cole). Hockey Player. He was about to shoot in the net from closer than the center column of the Ice Rink.",
    "D (Man - David). Hockey Player. He was the easternmost hockeyplayer.",
    "E (Woman - Echo). Her and 1 other person were the only ones on the outer edge of the arena.",
    "F (Woman - Flora). She was not sitting in a chair and was 2 columns away from Cole.",
    "G (Man - Gerald). He was sitting in a chair and was adjacent to exactly 2 chairs.",
    "H (Man - Hector). He was south-west of David. He was not sitting in a chair.",
    "V (Man - Vance). The victim. He was alone with the murderer."
  ],
  "difficulty": "Hard",
  "tags": [
    "Murdoku"
  ],
  "autoCrossRules": [
    "rook"
  ],
  "puzzleType": "murdoku",
  "clickActionRight": "cross",

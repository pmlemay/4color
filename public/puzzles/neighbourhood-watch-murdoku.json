  ],
  "rules": [
    "- Only 1 person per row and per column.",
    "- \"Beside\" means in the same area and orthogonally adjacent."
  ],
  "clues": [
    "A (Woman - Amanda) is beside a house, west of it.",
    "B (Man   - Brad) is beside a house, east of it.",
    "C (Woman - Carol) is in the Oak House region.",
    "D (Man   - Derek) was the only man on the Road.",
    "E (Woman - Elise) was beside the bicycle.",
    "F (Man   - Frank)  was in the top 2 rows, but not beside a house.",
    "V (Man   - Vincent) is the victim and is alone with the killer."

{
  "id": "pirate-ship-murdoku",
  "title": "Pirate Ship Murdoku",
  "authors": [
    "PmLemay"
  ],
  "specialRules": [
    "Only beds can be occupied, the other icons cannot"
  ],
  "rules": [
    "- Only 1 person per row and per column.",
    "- \"Beside\" means in the same area and orthogonally adjacent."
  ],
  "clues": [
    "A (Woman - Adelaide) was in a bed.",
    "B (Man   - Barnaby) was beside a cannon.",
    "C (Woman - Charlotte) was either beside the map or the mast",
    "D (Man   - Drake) was not alone in the Armory.",
    "E (Woman - Esmeralda) was alone in the Cargo.",
    "F (Man   - Fletcher) was beside the anchor",
    "G (Man   - Gideon) was alone beside the rudder in the Brig.",
    "H (Woman - Helena) was beside a treasure chest.",
    "V (Man   - Vasco) is the victim and was alone with the murderer."
  ],
  "difficulty": "Hard",
  "tags": [
    "Murdoku"
  ],
